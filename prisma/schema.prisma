generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id              String              @id @default(uuid())
  slug            String              @unique
  title           String
  description     String?
  ingredients     String[]
  ratingRate      Decimal             @default(0) @map("rating_rate") @db.Decimal(3, 2)
  ratingCount     Int                 @default(0) @map("rating_count")
  stock           Int                 @default(0)
  isSeed          Boolean             @default(false) @map("is_seed")
  measureType     MeasureType         @map("measure_type")
  measureValue    Decimal             @map("measure_value") @db.Decimal(10, 2)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  categoryId      String?             @map("category_id")
  regularPrice    Decimal             @map("regular_price") @db.Decimal(10, 2)
  salePrice       Decimal?            @map("sale_price") @db.Decimal(10, 2)
  effectivePrice  Decimal?            @default(dbgenerated("COALESCE(sale_price, regular_price)")) @map("effective_price") @db.Decimal(10, 2)
  discountPercent Int?                @default(dbgenerated("\nCASE\n    WHEN (sale_price IS NULL) THEN (0)::numeric\n    ELSE round((((regular_price - sale_price) / regular_price) * (100)::numeric))\nEND")) @map("discount_percent")
  collections     ProductCollection[]
  images          ProductImage[]
  category        Category?           @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([discountPercent])
  @@index([effectivePrice])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int     @default(0) @map("sort_order")
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sortOrder])
  @@index([productId])
  @@map("product_images")
}

model Category {
  id        String     @id @default(uuid())
  slug      String     @unique
  title     String     @unique
  image     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@index([parentId])
  @@map("categories")
}

model Collection {
  id        String              @id @default(uuid())
  slug      String              @unique
  title     String              @unique
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  products  ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  productId    String     @map("product_id")
  collectionId String     @map("collection_id")
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([productId])
  @@index([collectionId])
  @@map("product_collections")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  phone         String?  @unique
  role          UserRole @default(USER)
  isSeed        Boolean  @default(false) @map("is_seed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  user                  User      @relation(fields: [userId], references: [id])
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

enum MeasureType {
  GRAM
  MILLILITER
  PIECE
}

enum UserRole {
  ADMIN
  USER
}
